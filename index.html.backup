              <p style={{ fontSize:12, fontWeight:700, color:p.popular?T.green:T.g500, letterSpacing:0.5 }}>{p.name}</p>
            </div>
          ))}
        </div>

        <div style={{ borderRadius:16, overflow:"hidden", border:`1px solid ${T.g200}` }}>
          {[
            {label:"Monthly", vals:["$69","$99","$109"]},
            {label:"Activation", vals:["FREE","$99","$199"]},
            {label:"Max Speed", vals:["60 Mbps","250 Mbps","500 Mbps"]},
            {label:"Latency", vals:["40-80ms","30-60ms","20-40ms"]},
            {label:"Data Cap", vals:["None","None","None"]},
            {label:"Router", vals:["4G LTE","Cat12 AC","5G Premium"]},
            {label:"Weatherproof", vals:["--","--","IP65"]},
            {label:"Best For", vals:["Browsing","Streaming","4K/Gaming"]},
          ].map((row,i) => (
            <div key={i} style={{ display:"flex", alignItems:"center", borderTop:i?`1px solid ${T.g200}`:"none", background:i%2===0?T.g50:T.white }}>
              <div style={{ flex:1.2, padding:"13px 14px", fontSize:13, fontWeight:600, color:T.g700 }}>{row.label}</div>
              {row.vals.map((v,j) => (
                <div key={j} style={{ flex:1, padding:"13px 6px", fontSize:13, color:j===2?T.g900:T.g600, textAlign:"center", fontWeight:j===2?700:400, background:j===2?"rgba(85,182,133,0.04)":"transparent" }}>{v}</div>
              ))}
