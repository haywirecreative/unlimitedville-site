        <h2 style={{ fontSize:22, fontWeight:900, color:T.g900, marginBottom:24, textAlign:"center", letterSpacing:-0.3 }}>Included with every plan</h2>
        <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:18 }}>
          {[
            { t:"Unlimited data", d:"No overages, no throttling, ever", icon:I.signal(18,T.green) },
            { t:"No installation", d:"Plug in and connect in minutes", icon:I.zap(18,T.green) },
            { t:"USA-based support", d:"Real humans, available 24/7", icon:I.phone(18,T.green) },
            { t:"Travel-friendly", d:"Works at home, on the road, anywhere", icon:I.globe(18,T.green) },
            { t:"Advanced security", d:"Built-in protection for all devices", icon:I.shield(18,T.green) },
            { t:"Router included", d:"Pre-configured and ready to go", icon:I.router(18,T.green) },
          ].map((item,i) => (
            <div key={i} style={{ padding:"16px", borderRadius:14, background:T.g50, border:`1px solid ${T.g100}` }}>
              <div style={{ marginBottom:10 }}>{item.icon}</div>
              <p style={{ fontSize:14, fontWeight:700, color:T.g900, marginBottom:4 }}>{item.t}</p>
              <p style={{ fontSize:13, color:T.g500, lineHeight:1.4 }}>{item.d}</p>
            </div>
          ))}
        </div>
      </div>

      {/* ── GUARANTEES ── */}
      <div style={{ padding:"40px 20px", background:T.g50, borderTop:`1px solid ${T.g200}` }}>
        <h2 style={{ fontSize:22, fontWeight:900, color:T.g900, marginBottom:24, textAlign:"center", letterSpacing:-0.3 }}>Why Unlimitedville?</h2>
        <div style={{ display:"flex", flexDirection:"column", gap:14 }}>
          {[
            { emoji:"21 days", title:"Money-Back Guarantee", desc:"Try risk-free -- return within 21 days for a full refund, no questions asked" },
            { emoji:"Locked", title:"Price Lock Guarantee", desc:"Your rate stays locked for life. No hikes, no surprises, ever" },
            { emoji:"$0", title:"No Contracts", desc:"Month-to-month. Cancel anytime with zero penalties or fees" },
            { emoji:"24/7", title:"USA-Based Support", desc:"Real people ready to help whenever you need us" },
          ].map((g,i) => (
            <div key={i} style={{ display:"flex", gap:16, padding:"20px", background:T.white, borderRadius:16, border:`1px solid ${T.g200}` }}>
              <div style={{ minWidth:48, height:48, borderRadius:14, background:`${T.green}08`, border:`1px solid ${T.green}15`, display:"flex", alignItems:"center", justifyContent:"center", fontSize:14, fontWeight:800, color:T.green, flexShrink:0 }}>{g.emoji}</div>
              <div>
                <p style={{ fontSize:15, fontWeight:700, color:T.g900, marginBottom:4 }}>{g.title}</p>
                <p style={{ fontSize:13, color:T.g500, lineHeight:1.5 }}>{g.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* ── SOCIAL PROOF STRIP ── */}
      <div style={{ padding:"32px 20px", background:T.dark, borderTop:`1px solid ${T.darkBorder}` }}>
        <div style={{ display:"flex", alignItems:"center", justifyContent:"center", gap:8, marginBottom:20 }}>
          <div style={{ display:"flex", gap:2 }}>{[1,2,3,4,5].map(i=><span key={i}>{I.star(14)}</span>)}</div>
          <span style={{ fontSize:16, fontWeight:800, color:T.white }}>4.5</span>
          <span style={{ fontSize:13, color:T.g500 }}>from 213+ reviews</span>
        </div>
        {[
          { name:"Timothy R.", text:"Best speeds I've ever seen here. I can play games online and stream in 4K.", plan:"5G Ultra" },
          { name:"Elizabeth A.", text:"We could not be happier! Streaming works perfectly and setup was a breeze.", plan:"4G Plus" },
        ].map((r,i) => (
          <div key={i} style={{ padding:"16px", borderRadius:14, background:T.darkCard, border:`1px solid ${T.darkBorder}`, marginBottom:i===0?10:0 }}>
            <p style={{ fontSize:14, color:T.g300, lineHeight:1.6, fontStyle:"italic", marginBottom:10 }}>"{r.text}"</p>
            <div style={{ display:"flex", alignItems:"center", gap:8 }}>
              <div style={{ width:28, height:28, borderRadius:14, background:`${T.green}12`, display:"flex", alignItems:"center", justifyContent:"center", fontSize:12, fontWeight:700, color:T.green }}>{r.name[0]}</div>
              <span style={{ fontSize:13, fontWeight:600, color:T.g400 }}>{r.name}</span>
              <span style={{ fontSize:12, color:T.g600 }}>{r.plan}</span>
            </div>
          </div>
        ))}
        <button onClick={()=>navigate("reviews")} style={{ width:"100%", marginTop:16, padding:"14px", background:"none", border:`1px solid ${T.darkBorder}`, borderRadius:14, fontSize:14, fontWeight:600, color:T.g400, display:"flex", alignItems:"center", justifyContent:"center", gap:6 }}>Read all reviews {I.arrow(13,T.g400)}</button>
      </div>

      {/* ── FAQ ── */}
      <div style={{ padding:"48px 20px", background:T.white, borderTop:`1px solid ${T.g200}` }}>
        <h2 style={{ fontSize:22, fontWeight:900, color:T.g900, letterSpacing:-0.3, marginBottom:24, textAlign:"center" }}>Common questions</h2>
        {plansFaq.map((item,i) => (
          <div key={i} style={{ borderRadius:14, overflow:"hidden", background:T.g50, border:`1px solid ${faqOpen===i?T.green+"30":T.g200}`, marginBottom:8, transition:"border-color 0.2s" }}>
            <button onClick={()=>setFaqOpen(faqOpen===i?null:i)} style={{ width:"100%", padding:"18px 20px", background:"none", border:"none", fontSize:15, fontWeight:600, color:T.g900, textAlign:"left", display:"flex", justifyContent:"space-between", alignItems:"center" }}>
              <span style={{ paddingRight:12 }}>{item.q}</span>
              {faqOpen===i?I.chevUp(14,T.g400):I.chevDown(14,T.g400)}
            </button>
            {faqOpen===i && <div style={{ padding:"0 20px 18px", fontSize:15, color:T.g500, lineHeight:1.65 }}>{item.a}</div>}
          </div>
        ))}
      </div>

      {/* ── BOTTOM CTA ── */}
      <div style={{ position:"relative", overflow:"hidden" }}>
        <div style={{ position:"absolute", inset:0 }}>
          <img src={SITE_IMG} alt="" style={{ width:"100%", height:"100%", objectFit:"cover" }} />
          <div style={{ position:"absolute", inset:0, background:"linear-gradient(180deg, rgba(10,10,10,0.6) 0%, rgba(10,10,10,0.92) 100%)" }} />
        </div>
        <div style={{ position:"relative", zIndex:1, padding:"56px 24px 48px", textAlign:"center" }}>
          <h2 style={{ fontSize:32, fontWeight:900, color:T.white, letterSpacing:-0.8, lineHeight:1.08, marginBottom:14 }}>Ready to get<br/>connected?</h2>
          <p style={{ fontSize:15, color:T.g300, marginBottom:28, lineHeight:1.5 }}>Setup takes 5 minutes. No technicians,<br/>no contracts, no risk.</p>
          <button onClick={()=>window.scrollTo({top:0,behavior:"smooth"})} className="btn-primary" style={{ width:"100%", maxWidth:320, padding:"18px", margin:"0 auto", background:T.green, color:T.white, border:"none", borderRadius:14, fontSize:17, fontWeight:700, display:"flex", alignItems:"center", justifyContent:"center", gap:8, boxShadow:`0 0 50px ${T.greenGlow}, 0 6px 30px rgba(0,0,0,0.4)` }}>
            Choose Your Plan {I.arrow(16)}
          </button>
          <p style={{ fontSize:13, color:T.g500, marginTop:16 }}>Or call <a href="tel:+18884222907" style={{ color:T.green, fontWeight:600 }}>888.422.2907</a></p>
        </div>
      </div>
    </div>
  );
}

/* ═══════════════════════════════════════
   PLACEHOLDER PAGE
   ═══════════════════════════════════════ */
function PlaceholderPage({ title, subtitle }) {
  const { navigate } = useApp();
  return (
    <div style={{ minHeight:"100vh", background:T.dark, paddingTop:64, display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center", textAlign:"center", padding:"64px 24px" }}>
      <Logomark h={64} />
      <h1 style={{ fontSize:32, fontWeight:900, color:T.white, marginTop:28, letterSpacing:-0.8 }}>{title}</h1>
      <p style={{ fontSize:15, color:T.g500, marginTop:10, lineHeight:1.5, maxWidth:280 }}>{subtitle || "This page is coming soon."}</p>
      <button onClick={()=>navigate("home")} className="btn-secondary" style={{ marginTop:28, padding:"14px 28px", background:"rgba(255,255,255,0.04)", border:"1px solid rgba(255,255,255,0.1)", borderRadius:14, color:T.g300, fontSize:15, fontWeight:500 }}>
        Back to Home
      </button>
    </div>
  );
}

/* ═══════════════════════════════════════
   APP ROUTER
   ═══════════════════════════════════════ */
function App() {
  const [page, setPage] = useState("home");
  const [cart, setCart] = useState(null);

  function navigate(p) {
    setPage(p);
    window.scrollTo({ top:0, behavior:"instant" });
  }

  const ctx = { page, navigate, cart, setCart };

  function renderPage() {
    switch(page) {
      case "home": return <HomePage />;
      case "plans": return <PlansPage />;
      case "cart": return <CartPage />;
      case "checkout": return <CheckoutPage />;
      case "reviews": return <PlaceholderPage title="Reviews" subtitle="213+ verified member reviews. Read what real members are saying about Unlimitedville." />;
      case "blog": return <PlaceholderPage title="Blog" subtitle="Guides, tips, and news about wireless internet, rural connectivity, and life off the grid." />;
      case "support": return <PlaceholderPage title="Support & FAQs" subtitle="Get help with your service, find answers, or talk to a real person at 888.422.2907." />;
      case "login": return <PlaceholderPage title="Member Login" subtitle="Access your account, manage your plan, and track your usage." />;
      default:
        if (page.startsWith("uc-")) {
          const uc = USE_CASES.find(u => "uc-"+u.slug === page);
          return <PlaceholderPage title={uc ? `Internet for ${uc.label}` : "Use Case"} subtitle={uc?.desc} />;
        }
        return <PlaceholderPage title="Page Not Found" />;
    }
  }

  return (
    <AppContext.Provider value={ctx}>
      <Nav />
      {renderPage()}
      <StickyBar />
    </AppContext.Provider>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
</script>
</body>
</html>
