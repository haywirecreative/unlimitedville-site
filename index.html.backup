        </p>
      </div>

      {/* ── COVERAGE CHECKER ── */}
      <div style={{ padding:"40px 20px", margin:"32px 20px 0", background:T.dark, borderRadius:20, border:`1px solid ${T.darkBorder}` }}>
        <div style={{ display:"flex", alignItems:"center", gap:12, marginBottom:16 }}>
          <div style={{ width:40, height:40, borderRadius:12, background:`${T.green}10`, display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0 }}>{I.pin(20,T.green)}</div>
          <div>
            <h3 style={{ fontSize:18, fontWeight:700, color:T.white, lineHeight:1.1 }}>Check Your Coverage</h3>
