            <input type="text" placeholder="Enter ZIP code" value={zip} onChange={e=>setZip(e.target.value.replace(/\D/g,""))} maxLength={5}
              style={{ flex:1, padding:"15px 16px", borderRadius:12, border:`1px solid ${T.darkBorder}`, background:T.darkCard, color:T.white, fontSize:16, outline:"none" }} />
            <button onClick={()=>zip.length===5&&setZipChecked(true)} className="btn-primary" style={{ padding:"15px 24px", background:T.green, color:T.white, border:"none", borderRadius:12, fontSize:15, fontWeight:700, opacity:zip.length===5?1:0.35, transition:"opacity 0.2s" }}>Check</button>
          </div>
        ) : (
          <div style={{ padding:"16px", borderRadius:12, background:`${T.green}08`, border:`1px solid ${T.green}18` }}>
            <div style={{ display:"flex", alignItems:"center", gap:10, marginBottom:6 }}>
              <div style={{ width:24, height:24, borderRadius:12, background:T.green, display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0 }}>{I.check(14,T.white)}</div>
              <span style={{ fontSize:15, fontWeight:700, color:T.green }}>Coverage available in your area</span>
            </div>
            <p style={{ fontSize:13, color:T.g400, lineHeight:1.5, marginLeft:34 }}>Multiple carriers serve your area. All plans backed by our 21-day money-back guarantee.</p>
          </div>
        )}
        <p style={{ fontSize:12, color:T.g600, marginTop:12, display:"flex", alignItems:"center", gap:5 }}>
          {I.phone(12,T.g600)} Need help choosing? <a href="tel:+18884222907" style={{ color:T.green, fontWeight:600 }}>888.422.2907</a>
        </p>
      </div>

      {/* ── COMPARE PLANS TABLE ── */}
      <div style={{ padding:"48px 20px 40px" }}>
        <h2 style={{ fontSize:24, fontWeight:900, color:T.g900, marginBottom:6, textAlign:"center", letterSpacing:-0.5 }}>Compare Plans</h2>
        <p style={{ fontSize:14, color:T.g500, marginBottom:24, textAlign:"center" }}>Side-by-side, no fine print.</p>

        {/* Column headers */}
        <div style={{ display:"flex", marginBottom:4 }}>
          <div style={{ flex:1.2 }} />
          {PLANS.map((p,i) => (
